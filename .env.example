# =============================================================================
# DrugMesh Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# ---- Anthropic / Claude API ----
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- PubMed / NCBI (optional — free tier works without key) ----
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here

# ---- OpenFDA (optional — free, higher rate-limits with key) ----
# Register at: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=your_openfda_api_key_here

# ---- Application Settings ----
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change_me_to_a_long_random_string_min_32_chars

# ---- Database (if using SQLAlchemy / Neo4j) ----
DATABASE_URL=sqlite:///./drugmesh.db
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=60

# ---- CORS (comma-separated origins) ----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
